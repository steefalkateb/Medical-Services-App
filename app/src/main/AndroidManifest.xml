            android:theme="@style/AppTheme.ActionBar.Transparent" />
        <activity
            android:name=".Notifications"
            android:parentActivityName=".About_us"
            android:theme="@style/AppTheme.ActionBar.Transparent" />
        <activity
            android:name=".Appointment_Booking"
            android:parentActivityName=".About_us"
            android:theme="@style/AppTheme.ActionBar.Transparent" />
        <activity
            android:name=".ui.doctors.Details_Doctors"
            android:parentActivityName=".About_us"
            android:theme="@style/AppTheme.ActionBar.Transparent" />
        <activity
            android:name=".Register_Activity"
            android:parentActivityName=".About_us"
            android:theme="@style/AppTheme.ActionBar.Transparent" />
        <activity
            android:name=".ui.services.Details_Service_Clinic"
            android:parentActivityName=".About_us"
            android:theme="@style/AppTheme.ActionBar.Transparent" />
        <activity
            android:name=".About_us"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme.ActionBar.Transparent" />
