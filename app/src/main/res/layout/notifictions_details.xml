<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Notifictions_Details">

    <RelativeLayout
        android:id="@+id/rr"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#88000000">

        <ImageView
            android:id="@+id/movieImage"

            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="fitXY"
            android:src="@drawable/dermatophytes_img_1"></ImageView>

        <LinearLayout
            android:id="@+id/aa"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/bb"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:background="@drawable/shadow_service_clinic"
                android:gravity="center"
                android:orientation="horizontal">


            </LinearLayout>
        </LinearLayout>


    </RelativeLayout>
    <LinearLayout
        android:id="@+id/txt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rr"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/date_time"

            android:textStyle="bold"

            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="10dp"
            android:layout_weight="1.0"
            android:gravity="right"
            android:scrollbars="vertical"
            android:text="desc2"
            android:textColor="#A3000000"
            android:textSize="18dp"

            />


    </LinearLayout>

    <LinearLayout
        android:id="@+id/txt1"

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/xx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="التفاصيل :"
            android:textColor="@color/alwadi"
            android:textSize="15dp"
            android:textStyle="bold" />


    </LinearLayout>

    <ScrollView

        android:layout_width="fill_parent"
        android:layout_height="wrap_content"

        android:layout_below="@+id/txt1"
        android:fillViewport="true"
        android:orientation="vertical"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/zx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!--        <ScrollView-->
            <!--            android:id="@+id/SCROLLER_ID"-->
            <!--            android:layout_width="match_parent"-->
            <!--            android:layout_height="wrap_content"-->
            <!--            android:fillViewport="true"-->
            <!--            android:scrollbars="vertical">-->
            <TextView
                android:id="@+id/desc1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/name"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_weight="1"
                android:gravity="right"
                android:text=""
                android:textColor="#A3000000"
                android:textSize="15dp" />

            <View
                android:id="@+id/view1"
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:layout_below="@+id/desc1"
                android:layout_centerVertical="true"
                android:layout_marginTop="10dp"
                android:background="#ececec" />

            <TextView
                android:id="@+id/desc2"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="10dp"
                android:layout_weight="1.0"
                android:gravity="right"
                android:scrollbars="vertical"
                android:text=""
                android:textColor="#A3000000"
                android:textSize="18dp" />

            <!--        </ScrollView>-->
        </LinearLayout>

    </ScrollView>

</RelativeLayout>