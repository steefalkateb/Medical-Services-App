<?xml version="1.0" encoding="utf-8"?><!--    https://www.tutorialspoint.com/how-to-create-transparent-statusbar-and-actionbar-in-android-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5"
    tools:context=".ui.services.Details_Service_Clinic">


    <RelativeLayout
        android:id="@+id/rr"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#88000000">

        <ImageView
            android:id="@+id/movieImage"

            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="fitXY"
            android:src="@drawable/dermatophytes_img_1"></ImageView>

        <LinearLayout
            android:id="@+id/aa"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/bb"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:background="@drawable/shadow_service_clinic"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal|center_vertical"
                    android:text="معالجة آثار حب الشباب والندبات"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="15dp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btn_appointment_booking"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/appointment_booking_back"
                android:text="حجز موعد"
                android:textColor="@color/colorText"
                android:textSize="15dp" />
        </RelativeLayout>
    </RelativeLayout>


    <LinearLayout
        android:id="@+id/lLayoutBeginAdv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/rr"
        android:layout_marginLeft="50dp"
        android:layout_marginRight="50dp">


        <LinearLayout

            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_alignParentLeft="true"
            android:layout_weight=".5"
            android:background="@drawable/border_to_btn"
            android:baselineAligned="false"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/price_icon"></ImageView>

<!--            <TextView-->
<!--                android:id="@+id/price"-->
<!--                android:layout_width="wrap_content"-->

<!--                android:layout_height="wrap_content"-->
<!--                android:layout_gravity="center_horizontal"-->
<!--                android:layout_marginTop="10dp"-->
<!--                android:text="10000"-->
<!--                android:textAlignment="center">-->

<!--            </TextView>-->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:layout_toEndOf="@id/time"
                    android:layout_toRightOf="@id/time"
                    android:text="ل.س" />

                <TextView
                    android:id="@+id/price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2000" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout

            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_alignParentLeft="true"
            android:layout_weight=".5"
            android:background="@drawable/border_to_btn"
            android:baselineAligned="false"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/oclock_icon"></ImageView>

            <!--            <TextView-->
            <!--            android:id="@+id/time"-->
            <!--            android:layout_width="wrap_content"-->
            <!--            android:layout_height="wrap_content"-->
            <!--            android:layout_gravity="center_horizontal"-->
            <!--            android:layout_marginTop="10dp"-->
            <!--            android:text="20"-->
            <!--            android:textAlignment="center">-->

            <!--        </TextView>-->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:layout_toEndOf="@id/time"
                    android:layout_toRightOf="@id/time"
                    android:text="دقيقة" />

                <TextView
                    android:id="@+id/time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/txt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/lLayoutBeginAdv"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/mm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:text="تفاصيل :"
            android:textColor="@color/alwadi"
            android:textSize="15dp"
            android:textStyle="bold" />


    </LinearLayout>

    <ScrollView

        android:layout_width="fill_parent"
        android:layout_height="wrap_content"

        android:layout_below="@+id/txt"
        android:fillViewport="true"
        android:orientation="vertical"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/zx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!--        <ScrollView-->
            <!--            android:id="@+id/SCROLLER_ID"-->
            <!--            android:layout_width="match_parent"-->
            <!--            android:layout_height="wrap_content"-->
            <!--            android:fillViewport="true"-->
            <!--            android:scrollbars="vertical">-->
            <TextView
                android:id="@+id/desc1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/name"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_weight="1"
                android:gravity="right"
                android:text="desc1"
                android:textColor="#A3000000"
                android:textSize="15dp" />

            <View
                android:id="@+id/view1"
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:layout_below="@+id/desc1"
                android:layout_centerVertical="true"
                android:layout_marginTop="10dp"
                android:background="#ececec" />

            <TextView
                android:id="@+id/desc2"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="10dp"
                android:layout_weight="1.0"
                android:gravity="right"
                android:scrollbars="vertical"
                android:text="desc2"
                android:textColor="#A3000000"
                android:textSize="18dp" />

            <!--        </ScrollView>-->
        </LinearLayout>

    </ScrollView>

</RelativeLayout>



